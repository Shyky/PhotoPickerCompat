<?xml version="1.0" encoding="utf-8"?><!--
  ★ Ultra-light item layout — FrameLayout for zero constraint solving.
  All positioning via gravity; square size set programmatically via precomputedSquareSize.
  Overdraw: 2-3 passes max (thumb + hollow ring + optional mask/filled/number).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_margin="4dp">

    <!-- Layer 0: thumbnail fills parent — GPU texture cache avoids re-compositing during scroll -->
    <ImageView
        android:id="@+id/iv_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:layerType="hardware" />

    <!-- Layer 1 (selected): dim overlay, fills parent -->
    <View
        android:id="@+id/view_mask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A000000"
        android:visibility="gone" />

    <!-- Video: play icon badge, top-left -->
    <ImageView
        android:id="@+id/iv_play_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="6dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_play_badge"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_play_triangle"
        android:visibility="gone" />

    <!-- Video: duration label, bottom-right -->
    <TextView
        android:id="@+id/tv_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_video_timer_gradient"
        android:paddingHorizontal="4dp"
        android:paddingVertical="2dp"
        android:textColor="#FFFFFFFF"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- Check: merged stateful ring, top-right — hollow when unselected, filled when selected -->
    <View
        android:id="@+id/view_check_selected"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="end|top"
        android:layout_margin="6dp"
        android:background="@drawable/bg_check_hollow"
        android:visibility="visible" />

    <!-- Check: number overlay on top of ring, top-right -->
    <TextView
        android:id="@+id/tv_check_num"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="end|top"
        android:layout_margin="6dp"
        android:gravity="center"
        android:textColor="#FFFFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Camera icon, centered — GONE normally -->
    <ImageView
        android:id="@+id/iv_camera"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_camera"
        android:visibility="gone" />

</FrameLayout>
