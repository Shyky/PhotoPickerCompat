<?xml version="1.0" encoding="utf-8"?><!-- ★ 零嵌套: ConstraintLayout → ImageView + TextView 直接, 消去 CardView 层 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="12dp">

    <ImageView
        android:id="@+id/iv_folder_cover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_check_hollow"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_folder_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/iv_folder_cover"
        app:layout_constraintTop_toBottomOf="@id/iv_folder_cover" />

</androidx.constraintlayout.widget.ConstraintLayout>
